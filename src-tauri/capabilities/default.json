{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "opener:default",
    "websocket:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.github.com/**" }
      ]
    }
  ]
}
